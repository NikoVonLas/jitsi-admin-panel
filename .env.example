# Database password
DB_PASSWD=changeme

# API secret key (generate a strong random string)
API_SECRET=

# Hostname where the app is running (without protocol, e.g. example.com)
# Production:  APP_FQDN=example.com  — Caddy auto-issues a Let's Encrypt cert
# Local HTTPS: APP_FQDN=localhost    — Caddy uses its internal CA (run `docker compose exec ui caddy trust` once)
# Local HTTP:  APP_FQDN=:80          — no TLS, open http://localhost
APP_FQDN=localhost


# Mailer configuration
MAILER_HOST=
MAILER_PORT=465
MAILER_SECURE=true
MAILER_USER=
MAILER_PASS=
MAILER_FROM=

# Auth: email/password login (true by default)
AUTH_LOCAL=true

# Allow self-signed TLS certificates (development only)
ALLOW_UNSECURE_CERT=false

# API request timeout in milliseconds
API_TIMEOUT=30000

# Contact email shown in the admin panel
CONTACT_EMAIL=
