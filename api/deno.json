{
  "imports": {
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "@emrahcom/jwt": "jsr:@emrahcom/jwt@^0.4.8",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/http": "jsr:@std/http@^1.0.24",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@std/uuid": "jsr:@std/uuid@^1.1.0",
    "nodemailer": "npm:nodemailer@^8.0.1",
    "favicons": "npm:favicons@^7.2.0"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "test": "deno test --allow-all --env=test/env.test --coverage=cov_profile test/",
    "test:coverage": "deno task test && deno coverage cov_profile --lcov --output=coverage/lcov.info",
    "migrate:test": "deno run --allow-all --env=test/env.test test/migrate.ts"
  }
}
